class Solution {
    public int maxProfit(int[] prices) {
        int maxProfit=0;
        int minPrice=prices[0];
        for(int j=1;j<prices.length;j++){
            minPrice=Math.min(prices[j],minPrice);           //Minimum price for buying before each day
            int currProfit=prices[j]-minPrice;               //Calculating profit for each day
            maxProfit=Math.max(maxProfit,currProfit);        //Finding maximum profit
        }
        return maxProfit;
    }
}
